# ============================================================
#  CanchaYa — Variables de entorno
#  Copiá este archivo como .env y completá los valores
# ============================================================

# ── Base de datos ────────────────────────────────────────────
# Local:        postgresql://usuario:password@localhost:5432/canchas_db
# DigitalOcean: se copia del panel (incluye ?sslmode=require)
DATABASE_URL=postgresql://usuario:password@localhost:5432/canchas_db

# ── CORS ─────────────────────────────────────────────────────
# Desarrollo:   http://localhost:5500,http://127.0.0.1:5500
# Producción:   https://tu-frontend.ondigitalocean.app
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://bitter-surf-d556.lucascapocasa1.workers.dev

# ── URLs públicas ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5500
BACKEND_URL=http://localhost:8000

# ── Mercado Pago ──────────────────────────────────────────────
# Obtenelo en: mercadopago.com.ar/developers → tu app → Credenciales de prueba
# El Access Token de PRUEBA empieza con TEST-
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── JWT ───────────────────────────────────────────────────────
# Cambiala por algo largo y aleatorio en producción
SECRET_KEY=dev-secret-key-change-in-production-please

# ── Resend (emails — opcional) ────────────────────────────────
# Sin esto la app funciona igual (el email se loggea en consola)
RESEND_API_KEY=
FROM_EMAIL=noreply@example.com

# ── Ambiente ──────────────────────────────────────────────────
ENV=development
